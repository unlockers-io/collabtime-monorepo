# =============================================================================
# Collabtime — Local Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are required unless marked [OPTIONAL].
# =============================================================================

# Database (PostgreSQL via Docker)
DATABASE_URL="postgresql://collabtime:collabtime123@localhost:5432/collabtime"

# Better Auth
BETTER_AUTH_SECRET=local-dev-secret-minimum-32-characters-long!!
BETTER_AUTH_URL=https://collabtime.web.localhost

# Upstash Redis (local Docker)
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=local-dev-token

# App URL
WEB_APP_URL=https://collabtime.web.localhost

# [OPTIONAL] Space access token signing — falls back to BETTER_AUTH_SECRET
SPACE_ACCESS_SECRET=

# [OPTIONAL] Resend email
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Environment
NODE_ENV=development
