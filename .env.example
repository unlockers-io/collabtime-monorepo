# =============================================================================
# Collabtime — Local Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are required unless marked [OPTIONAL].
# =============================================================================

# Database (PostgreSQL via Docker)
DATABASE_URL="postgresql://collabtime:collabtime123@localhost:5433/collabtime"

# Better Auth (base URL derived from request via dynamic baseURL — set
# AUTH_ALLOWED_HOSTS for prod/preview hosts beyond *.localhost).
BETTER_AUTH_SECRET=local-dev-secret-minimum-32-characters-long!!

# Redis (local Docker / Railway)
# Accepts redis:// or rediss:// (TLS)
REDIS_URL=redis://localhost:6379

# App URL
WEB_APP_URL=https://collabtime.web.localhost

# [OPTIONAL] Space access token signing — falls back to BETTER_AUTH_SECRET
SPACE_ACCESS_SECRET=

# [OPTIONAL] Resend email
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Environment
NODE_ENV=development
