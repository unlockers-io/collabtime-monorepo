{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignoreBinaries": ["portless"],
  "ignoreDependencies": [
    "eslint-plugin-*",
    "oxlint-config-awesomeness",
    "postcss",
    "postcss-load-config",
    "react-scan",
    "tailwindcss",
    "jsdom",
    "shadcn",
    "@testing-library/user-event"
  ],
  "ignore": ["packages/db/src/generated/**"],
  "exclude": ["unresolved", "exports"],
  "workspaces": {
    ".": {
      "entry": ["tests/e2e/**/*.{ts,tsx}"]
    },
    "packages/ui": {
      "entry": ["src/components/**/*.{ts,tsx}", "src/lib/**/*.{ts,tsx}"]
    }
  }
}
