# =============================================================================
# Collabtime Web App Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All variables are required unless marked [OPTIONAL].
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PlanetScale)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://collabtime:collabtime123@localhost:5433/collabtime

# -----------------------------------------------------------------------------
# Upstash Redis
# -----------------------------------------------------------------------------
# For local dev with docker-compose (redis-rest service):
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=local-dev-token
# For production, use your Upstash dashboard values:
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-super-secret-key-here-minimum-32-chars
# The URL where your app is hosted
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Web App URL [OPTIONAL]
# -----------------------------------------------------------------------------
# Used for redirects and metadata. Falls back to BETTER_AUTH_URL if not set.
WEB_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Space Access Token Signing [OPTIONAL]
# -----------------------------------------------------------------------------
# If not set, falls back to BETTER_AUTH_SECRET
# SPACE_ACCESS_SECRET=your-space-access-secret-here
