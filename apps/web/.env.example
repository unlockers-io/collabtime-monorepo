# =============================================================================
# Collabtime Web App Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All variables are required unless marked [OPTIONAL].
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Docker locally; Railway in production)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://collabtime:collabtime123@localhost:5433/collabtime

# -----------------------------------------------------------------------------
# Redis (Railway / self-hosted)
# -----------------------------------------------------------------------------
# Standard RESP-over-TCP. Accepts redis:// or rediss:// (TLS).
# Local dev: redis://localhost:6379
# Railway: rediss://default:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32. The base URL is derived from the
# request via Better Auth's dynamic baseURL (allowedHosts) — set
# AUTH_ALLOWED_HOSTS for prod/preview hosts beyond *.localhost.
BETTER_AUTH_SECRET=your-super-secret-key-here-minimum-32-chars

# -----------------------------------------------------------------------------
# Web App URL
# -----------------------------------------------------------------------------
# Used for absolute URLs in outbound email (invitation links) and metadata.
WEB_APP_URL=https://collabtime.web.localhost

# -----------------------------------------------------------------------------
# Space Access Token Signing [OPTIONAL]
# -----------------------------------------------------------------------------
# If not set, falls back to BETTER_AUTH_SECRET
# SPACE_ACCESS_SECRET=your-space-access-secret-here
