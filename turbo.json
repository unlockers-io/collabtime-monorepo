{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["NODE_ENV", "DATABASE_URL"],
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "dependsOn": ["^build"],
      "env": [
        "AUTH_ALLOWED_HOSTS",
        "BETTER_AUTH_SECRET",
        "SPACE_ACCESS_SECRET",
        "WEB_APP_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PRO_PRICE_ID",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "REDIS_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "format:check": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": [
        "AUTH_ALLOWED_HOSTS",
        "BETTER_AUTH_SECRET",
        "SPACE_ACCESS_SECRET",
        "WEB_APP_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PRO_PRICE_ID",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "REDIS_URL"
      ]
    },
    "dev:ci": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": [
        "AUTH_ALLOWED_HOSTS",
        "BETTER_AUTH_SECRET",
        "SPACE_ACCESS_SECRET",
        "WEB_APP_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PRO_PRICE_ID",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "REDIS_URL"
      ]
    },
    "start": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": [
        "AUTH_ALLOWED_HOSTS",
        "BETTER_AUTH_SECRET",
        "SPACE_ACCESS_SECRET",
        "WEB_APP_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PRO_PRICE_ID",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "REDIS_URL"
      ]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false,
      "env": [
        "AUTH_ALLOWED_HOSTS",
        "BETTER_AUTH_SECRET",
        "SPACE_ACCESS_SECRET",
        "WEB_APP_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PRO_PRICE_ID",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "REDIS_URL",
        "DATABASE_URL"
      ]
    },
    "test:watch": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    }
  }
}
