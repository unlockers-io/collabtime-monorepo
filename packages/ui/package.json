    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@repo/config-vitest": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "^19.2.14",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
