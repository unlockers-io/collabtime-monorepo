{
  "name": "@repo/db",
  "files": [
    "dist/**",
    "src/**",
    "prisma/schema.prisma"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate && tsdown",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "postinstall": "pnpm run db:generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@repo/config-vitest": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.0",
    "@types/pg": "8.20.0",
    "prisma": "^7.8.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
