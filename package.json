{
  "name": "collabtime",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "turbo run start",
    "dev": "turbo run dev --concurrency 16",
    "lint": "turbo run lint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "knip": "knip",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@upstash/redis": "^1.37.0",
    "husky": "^9.1.7",
    "knip": "^6.2.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-config-awesomeness": "^1.2.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint"
    ],
    "*.{ts,tsx,js,jsx,json,md}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "@types/pg": "8.11.11",
      "next": ">=16.2.2"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild",
      "msw",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
